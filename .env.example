# Upstash Redis REST (Marketplace / dashboard — use the default / read-write token for the app)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional aliases if you named them in Vercel:
# SUMIRAN_KV_REST_API_URL=
# SUMIRAN_KV_REST_API_TOKEN=

# Web Push VAPID — run: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Shared secret for cron-job.org (Authorization: Bearer <value> or x-cron-secret header)
CRON_SECRET=
